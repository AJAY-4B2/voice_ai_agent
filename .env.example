# 2Care.ai Voice AI Agent — Environment Configuration
# Copy to .env and fill in your values

# ── LLM Provider ────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic          # "anthropic" or "openai"
LLM_MODEL=claude-3-5-haiku-20241022

ANTHROPIC_API_KEY=sk-ant-...    # Get from https://console.anthropic.com
OPENAI_API_KEY=sk-...           # Get from https://platform.openai.com

# ── Speech Services ─────────────────────────────────────────────────────────
# STT: OpenAI Whisper (default) or Google
WHISPER_MODEL=whisper-1

# TTS: "openai" (default) or "google"
TTS_PROVIDER=openai
GOOGLE_TTS_KEY=                 # Google Cloud TTS API key (optional)

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Database (optional — defaults to in-memory) ──────────────────────────────
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/care_appointments

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development             # "development" | "production"
LOG_LEVEL=INFO
